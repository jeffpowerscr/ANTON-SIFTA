# ── Python ────────────────────────────────────────────────────────────────────
*.pyc
*.pyo
__pycache__/
*.egg-info/
dist/
build/
.venv/
venv/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── IDE ───────────────────────────────────────────────────────────────────────
.cursor_identity
.cursorrules
.vscode/

# ── SIFTA Runtime State (never version swarm runtime) ────────────────────────
# Agent JSON state is managed by the swarm; commit only intentional snapshots.
# Committed state (node_pki_registry.json, genesis_log.jsonl) tracked explicitly.
.sifta_state/*.json
.sifta_state/*.jsonl
!.sifta_state/node_pki_registry.json
!.sifta_state/genesis_log.jsonl
# Ledger files — single-writer truth, not versioned per-machine
repair_log.jsonl
STGM_TX_LOG.jsonl
hermes_stdout.log
m5queen_dead_drop.jsonl

# Session / trace logs
decision_trace.log
watcher_metrics.jsonl
sifta_session_log/
*.log

# Locked / process files
*.lock
.sifta_state/*.lock
.sifta_state/*.pid
.sifta_state/*.bak
.sifta_state/*.bak.*

# Compiled native helpers (build per platform; never commit binary)
.sifta_state/sifta_face_detect

# Scratch / large archives
scratch.py
*.zip
.sifta_state/*.pre_smoke_cleanup_backup
.sifta_state/iris_frames/
.sifta_state/acoustic_fields/
.sifta_state/archive/
.sifta_state/quarantine/
.sifta_state/_ssp_smoke/

# Migration artifacts
.sifta_state/*_MIGRATED.json
.sifta_state/migration_log.jsonl

# Binary / DB
*.db
*.sqlite

# ── Cryptographic Key Material (NEVER commit private keys) ───────────────────
~/.sifta/
~/.sifta_keys/
*.pem
*.key
!*.pub.pem

# ── Owner Genesis (photo NEVER in git — only hash in ledger) ─────────────────
# The photo lives at ~/.sifta_keys/owner_genesis/ (covered above)
# The genesis scar hash is in .sifta_state/owner_genesis.json (tracked)
!.sifta_state/owner_genesis.json
!.sifta_state/chorus_consent.json

